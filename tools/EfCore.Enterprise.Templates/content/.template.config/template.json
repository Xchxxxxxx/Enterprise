{
  "$schema": "http://json.schemastore.org/template",
  "author": "EfCore.Enterprise",
  "classifications": ["Web", "EF Core", "DDD", "Enterprise"],
  "identity": "EfCore.Enterprise.Template",
  "name": "EfCore.Enterprise 企业级项目模板",
  "shortName": "ef-enterprise",
  "description": "基于 DDD 的六层企业级 EF Core 开发框架模板",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "CompanyName",
  "preferNameDirectory": true,
  "symbols": {
    "Database": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "mysql", "description": "MySQL" },
        { "choice": "sqlserver", "description": "SQL Server" },
        { "choice": "postgresql", "description": "PostgreSQL" }
      ],
      "defaultValue": "mysql",
      "description": "数据库类型"
    },
    "DomainGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "11111111-1111-1111-1111-111111111111"
    },
    "SharedGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "22222222-2222-2222-2222-222222222222"
    },
    "ContractsGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "33333333-3333-3333-3333-333333333333"
    },
    "ApplicationGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "44444444-4444-4444-4444-444444444444"
    },
    "InfrastructureGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "55555555-5555-5555-5555-555555555555"
    },
    "WebApiGuid": {
      "type": "generated",
      "generator": "guid",
      "replaces": "66666666-6666-6666-6666-666666666666"
    }
  },
  "primaryOutputs": [
    { "path": "06-Presentation\\CompanyName.WebApi.csproj" }
  ],
  "postActions": [
    {
      "condition": "(Database == 'sqlserver')",
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "manualInstructions": [
        { "text": "请安装 SQL Server 的 EF Core 包: dotnet add package Microsoft.EntityFrameworkCore.SqlServer" }
      ]
    },
    {
      "condition": "(Database == 'postgresql')",
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "manualInstructions": [
        { "text": "请安装 PostgreSQL 的 EF Core 包: dotnet add package Npgsql.EntityFrameworkCore.PostgreSQL" }
      ]
    }
  ]
}