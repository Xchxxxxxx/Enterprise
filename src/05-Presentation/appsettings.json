{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "EfCore.Enterprise": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/efcore-enterprise-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "efcore-enterprise-{0:yyyy.MM.dd}",
          "autoRegisterTemplate": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EfCoreEnterprise;User=root;Password=123456;Charset=utf8mb4;",
    "Redis": ""
  },
  "Jwt": {
    "SecretKey": "EfCore-Enterprise-Super-Secret-Key-2024-Must-Be-At-Least-32-Characters!",
    "Issuer": "EfCore.Enterprise",
    "Audience": "EfCore.Enterprise.Client",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 7
  },
  "OpenTelemetry": {
    "Endpoint": ""
  },
  "Hangfire": {
    "Enabled": false
  },
  "Cache": {
    "DistributedCacheEnabled": false,
    "DefaultExpiryMinutes": 30,
    "BloomFilterExpectedElements": 1000000,
    "BloomFilterFalsePositiveRate": 0.01
  },
  "Resilience": {
    "RetryCount": 3,
    "RetryDelayMs": 1000,
    "CircuitBreakerExceptionsAllowed": 5,
    "CircuitBreakerDurationSeconds": 30,
    "TimeoutSeconds": 30,
    "BulkheadMaxParallelization": 10,
    "BulkheadMaxQueuing": 50
  },
  "RateLimit": {
    "MaxRequestsPerMinute": 100,
    "BlacklistThresholdMinutes": 5
  },
  "Compliance": {
    "LogPath": "logs/compliance",
    "ArchivePath": "logs/archive"
  },
  "AllowedHosts": "*"
}